{
  "manifest_version": 3,
  "name": "Google Maps Lead Scraper",
  "version": "1.8",
  "description": "Scrape local business leads from Google Maps automatically while scrolling.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*"
      ],
      "js": [
        "scripts/content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}